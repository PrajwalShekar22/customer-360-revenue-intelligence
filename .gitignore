# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Conda ────────────────────────────────────────────────
.conda/

# ── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files (never commit actual data to Git) ─────────
# Ignore data files but always allow .gitkeep placeholders
data/raw/*.xlsx
data/raw/*.csv
data/raw/*.parquet
data/raw/*.zip
data/raw/*.feather
data/interim/*.csv
data/interim/*.parquet
data/interim/*.feather
data/processed/*.csv
data/processed/*.parquet
data/processed/*.feather

# ── Model artifacts (binaries excluded; JSON metadata tracked) ───────────────
models/*.pkl
models/*.joblib

# ── macOS system files ───────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── VS Code ──────────────────────────────────────────────
.vscode/
*.code-workspace

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── Generated chart images (large binaries) ──────────────
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.html

# ── Screenshots (add manually with git add -f if needed) ─
reports/screenshots/*.png
reports/screenshots/*.jpg

# ── Loose data files dropped in project root ─────────────
*.xlsx
*.zip

# ── Secrets / credentials ────────────────────────────────
*.env
secrets.json
credentials.json
service_account*.json
